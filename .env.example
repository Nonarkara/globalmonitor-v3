# Globalmonitor environment variables (all optional for local dev)
# Copy to .env.local and fill in real secrets; never commit secrets.

# Server
PORT=4000
NODE_ENV=development
RENDER=

# Supabase (optional — falls back to direct fetches if missing)
GM_SUPABASE_URL=https://qbatksnulitgrhigzbta.supabase.co
GM_SUPABASE_SERVICE_KEY=

# Copernicus Sentinel Hub (optional)
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# AIS ship tracking (optional)
AISSTREAM_API_KEY=

# OpenSky ADS-B (optional)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Aviationstack flight supplement (optional, quota-safe 8h backend cache)
AVIATIONSTACK_API_KEY=

# Aviation Edge (optional)
AVIATION_EDGE_KEY=

# ACLED conflict events (optional)
ACLED_API_KEY=

# EIA oil prices (optional)
EIA_API_KEY=

# NASA FIRMS hotspots (optional)
FIRMS_MAP_KEY=

# Google Sheets recording (optional)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Frontend API base (optional — dev stack proxies /api automatically)
VITE_API_BASE_URL=
